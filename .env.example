# Claude Code SDK
OPENAI_BASE_URL=https://api-inference.modelscope.cn
OPENAI_API_KEY=
OPENAI_MODEL=moonshotai/Kimi-K2.5

#ANTHROPIC_BASE_URL=
#ANTHROPIC_AUTH_TOKEN=
#ANTHROPIC_MODEL=kimi-k2.5

# 钉钉
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=
#DINGTALK_WEBHOOK_SECRET=
# LLM 会通过 should_notify 判断是否值得发送钉钉通知；LGTM 等无问题结果默认跳过通知
# 联系人配置（JSON），用于钉钉 @mention
#AIR_CONTACTS={"users":[{"name":"张三","email":"zhangsan@example.com","phone":"13800138000","regex":"zhangsan","role":"maintainer"}]}
# 项目名称（可选；未设置时优先使用 CI_PROJECT_PATH / CI_PROJECT_NAME，再回退到工作目录名）
#AIR_PROJECT_NAME=group/project

# Jira 工单上下文（可选；未配置 JIRA_URL + 认证信息时不会注入 MCP）
# 自建 Jira Server/Data Center 推荐使用 Personal Access Token
# 注意 .env 不是 JSON/TOML，变量行末不要加逗号
#JIRA_URL=http://jira.example.com:8080
#JIRA_PERSONAL_TOKEN=
# 默认只读，review 不会创建、修改或流转 Jira 工单
#AIR_JIRA_MCP_READ_ONLY=true
# 如需强制开关可显式设置；未设置时会根据 JIRA_URL + 认证信息自动判断
#AIR_JIRA_MCP_ENABLED=true
# 默认使用 uv tool run mcp-atlassian 启动
#AIR_JIRA_MCP_COMMAND=uv
#AIR_JIRA_MCP_ARGS=tool run mcp-atlassian
#AIR_JIRA_MCP_TOOLSETS=default
#JIRA_PROJECTS_FILTER=AMA,PMIS
#JIRA_SSL_VERIFY=true

# Claude Code 工作目录（本地测试时指向被审查的代码仓库）
AIR_WORK_DIR=/workspace
# 本地测试
REPO_PATH=/Path/To/Code

CI_COMMIT_SHA=406cf05a
CI_COMMIT_BEFORE_SHA=406cf05a
CLAUDE_MAX_TURNS=30
